# ===========================================
# .easignore - Files excluded from EAS builds
# ===========================================

# Backend (not needed for mobile builds)
../backend/

# Documentation & project-level files
../docs/
../changelog.md
../readme.md
../UI_list.md
../manual_tests.md

# Git
../.git/
../.gitignore

# Dependencies (EAS installs these from package.json)
node_modules/

# Expo local caches
.expo/
dist/
web-build/
.expo-shared/

# Environment variables (use EAS secrets instead)
.env

# IDE & editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Firebase service account key (sensitive)
ameame-shop-firebase-adminsdk-fbsvc-a5b8c6e0fc.json

# Firebase
firebase-debug.log
.firebase/

# ESLint
.eslintcache
.eslintrc.cjs

# Test files
scripts/

# Lock file (EAS uses package.json)
# package-lock.json
